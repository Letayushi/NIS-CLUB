generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  role            String   // guest | student | owner | admin
  grade           String?
  phone           String?
  bio             String?
  avatar          String?
  createdAt       DateTime @default(now())

  ownedClubs      ClubOwner[]
  clubMemberships ClubMember[]
  announcements   Announcement[]
  comments        Comment[]
  announcementLikes AnnouncementLike[]
  clubRequests    ClubRequest[]     @relation("Applicant")
  joinRequests    JoinRequest[]

  @@map("users")
}

model Club {
  id              String   @id @default(cuid())
  name            String
  description     String
  shortDescription String
  coverImage      String
  photos          String   // JSON array
  schedule        String   // JSON array
  links           String   // JSON object
  city            String
  memberCount     Int      @default(0)
  categories      String   // JSON array
  createdAt       DateTime @default(now())

  owners          ClubOwner[]
  members         ClubMember[]
  announcements   Announcement[]
  achievements    Achievement[]
  clubRequests    ClubRequest[]     @relation("ApprovedClub")
  joinRequests    JoinRequest[]

  @@map("clubs")
}

model ClubOwner {
  clubId String
  userId String
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([clubId, userId])
  @@map("club_owners")
}

model ClubMember {
  clubId String
  userId String
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([clubId, userId])
  @@map("club_members")
}

model Announcement {
  id        String   @id @default(cuid())
  clubId    String
  title     String
  content   String
  image     String?
  authorId  String
  createdAt DateTime @default(now())

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     AnnouncementLike[]

  @@map("announcements")
}

model Comment {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  content        String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model AnnouncementLike {
  announcementId String
  userId         String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([announcementId, userId])
  @@map("announcement_likes")
}

model Achievement {
  id          String   @id @default(cuid())
  clubId      String
  title       String
  description String
  date        String
  image       String?
  icon        String?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model ClubRequest {
  id           String   @id @default(cuid())
  applicantId  String
  clubName     String
  description  String
  goals        String
  schedule     String   // JSON
  curator      String?
  contacts     String
  status       String   // pending | approved | rejected
  adminComment String?
  createdAt    DateTime @default(now())
  approvedClubId String? // set when approved -> created club id

  applicant    User     @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  approvedClub Club?   @relation("ApprovedClub", fields: [approvedClubId], references: [id])

  @@map("club_requests")
}

model JoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  name      String
  grade     String
  contacts  String
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("join_requests")
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String
  link        String
  icon        String
  platform    String
  memberCount Int?

  @@map("communities")
}
